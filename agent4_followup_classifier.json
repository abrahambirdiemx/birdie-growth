                  "leftValue": "",
                  "typeValidation": "loose"
                },
                "conditions": [
                  {
                    "id": "c4",
                    "leftValue": "={{ $json.classification }}",
                    "rightValue": "no_interesado",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "no_interesado"
            }
          ]
        },
        "fallbackOutput": "extra"
      }
    },
