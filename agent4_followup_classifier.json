    {
      "id": "node-merge-context",
      "name": "Merge Email + Contact Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1560,
        180
      ],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Merge contact sheet data with the incoming email\nconst contactRow  = $json; // from Find Contacto\nconst emailData   = $('Extract Sender Email').item.json;\n\nreturn {\n  json: {\n    // contact fields\n    row_number: contactRow.row_number,\n    contacto_id: contactRow.contacto_id,\n    empresa: contactRow.empresa,\n    nombre: contactRow.nombre,\n    cargo: contactRow.cargo,\n    tipo_contacto: contactRow.tipo_contacto,\n    email: contactRow.email,\n    // incoming email fields\n    gmail_message_id: emailData.id,\n    gmail_thread_id: emailData.threadId,\n    email_body: emailData.email_body,\n    email_subject_received: emailData.Subject || emailData.subject || ''\n  }\n};"
      }
    },
    {
      "id": "node-claude-classify",
      "name": "Claude - Classify Response",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1780,
        180
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-haiku-4-5-20251001\",\n  \"max_tokens\": 100,\n  \"system\": \"Clasifica el email de respuesta de un prospecto. El tipo de contacto es: {{ $json.tipo_contacto }}.\\n\\nSi tipo_contacto es 'decision_maker', usa EXACTAMENTE una de estas etiquetas: interesado | pide_info | no_interesado | fuera_oficina | otro\\n\\nSi tipo_contacto es 'referidor', usa EXACTAMENTE una de estas etiquetas: conecta_dm | no_interesado | fuera_oficina | pide_info | otro\\n\\nResponde SOLO con la etiqueta, sin explicación.\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Tipo de contacto: {{ $json.tipo_contacto }}\\nNombre: {{ $json.nombre }}\\nCargo: {{ $json.cargo }}\\nEmpresa: {{ $json.empresa }}\\n\\nContenido del email recibido:\\n{{ $json.email_body }}\"\n    }\n  ]\n}",
        "options": {
          "response": {
            "response": {
              "neverError": true,
              "responseFormat": "json"
            }
          }
        }
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "claude-api-credential",
          "name": "Claude API"
        }
      }
    },
    {
      "id": "node-parse-classification",
      "name": "Parse Classification",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2000,
        180
      ],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const content = $json.content && $json.content[0] ? $json.content[0].text : '';\nconst label   = content.trim().toLowerCase().replace(/[^a-z_]/g, '');\n\n// Normalize label\nconst validDM  = ['interesado', 'pide_info', 'no_interesado', 'fuera_oficina', 'otro'];\nconst validRef = ['conecta_dm', 'no_interesado', 'fuera_oficina', 'pide_info', 'otro'];\n\nconst contactCtx = $('Merge Email + Contact Context').item.json;\nconst tipo       = contactCtx.tipo_contacto;\n\nconst validSet = tipo === 'decision_maker' ? validDM : validRef;\nconst classification = validSet.includes(label) ? label : 'otro';\n\nreturn {\n  json: {\n    ...contactCtx,\n    classification\n  }\n};"
      }
    },
    {
      "id": "node-switch-action",
