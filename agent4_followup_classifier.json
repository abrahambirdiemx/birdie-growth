    {
      "id": "node-extract-sender",
      "name": "Extract Sender Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        300
      ],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Extract clean sender email from the From header\nconst from = $json.From || $json.from || '';\nconst emailMatch = from.match(/<([^>]+)>/) || from.match(/([\\w.+-]+@[\\w.-]+\\.[a-zA-Z]{2,})/);\nconst senderEmail = emailMatch ? emailMatch[1].trim().toLowerCase() : from.trim().toLowerCase();\n\nreturn {\n  json: {\n    ...$json,\n    sender_email: senderEmail,\n    email_body: $json.text || $json.snippet || ''\n  }\n};"
      }
    },
    {
      "id": "node-find-contacto",
