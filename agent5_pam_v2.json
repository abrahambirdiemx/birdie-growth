        "jsCode": "const items = $input.all();\nconst resp = items[0].json;\nlet ctx = {};\ntry { ctx = $('Code - Select Best Contact').all()[0].json || {}; } catch(e) {}\n\nconst text = resp?.content?.[0]?.text || '';\nconst subjectMatch = text.match(/\\[SUBJECT:\\s*(.+?)\\]/);\nconst subject = subjectMatch ? subjectMatch[1].trim() : 'Seguimiento Birdie';\nconst body = text.replace(/\\[SUBJECT:[^\\]]+\\]\\n?/, '').trim();\n\nreturn [{ json: {\n  deal_id: String(ctx.deal_id || ''),\n  empresa: String(ctx.empresa || ''),\n  status: String(ctx.status || ''),\n  contact_email: String(ctx.contact_email || ''),\n  contact_name: String(ctx.contact_name || ''),\n  email_subject: subject,\n  email_body: body,\n}}];"
