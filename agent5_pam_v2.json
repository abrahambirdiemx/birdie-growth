    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst deals = Array.isArray(items[0].json) ? items[0].json : [];\nconst today = new Date().toISOString().slice(0,10);\nconst filtered = deals.filter(d => {\n  if (!d.opportunity_name && !d.company?.nombre) return false;\n  const nt = d.next_touchpoint;\n  return !nt || nt <= today;\n});\nreturn filtered.map(d => ({ json: {\n  deal_id: String(d.id || ''),\n  company_id: String(d.company_id || ''),\n  empresa: String(d.opportunity_name || d.company?.nombre || ''),\n  status: String(d.status || ''),\n  owner: String(d.owner || 'Abraham Lopez'),\n  mrr: Number(d.mrr || 0),\n  acv: Number(d.acv || 0),\n  notes: String(d.notes || ''),\n  industria: String(d.company?.industria || ''),\n  canal: String(d.company?.canal || d.estrategia || ''),\n}}));"
      },
