    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst contacts = Array.isArray(items[0].json) ? items[0].json : [];\nlet dealData = {};\ntry { dealData = $('SplitInBatches').all()[0].json || {}; } catch(e) {}\n\n// Prefer decision_maker, then any contact with email\nconst dm = contacts.find(c => c.tipo_contacto === 'decision_maker' && c.email);\nconst best = dm || contacts.find(c => c.email);\n\nif (!best) {\n  return [{ json: { _no_contact: true, empresa: dealData.empresa, deal_id: dealData.deal_id } }];\n}\n\n// Clean markdown email format if needed\nconst emailRaw = String(best.email || '');\nconst email = emailRaw.replace(/\\[([^\\]]+)\\]\\([^)]+\\)/, '$1').trim();\n\nreturn [{ json: {\n  deal_id: String(dealData.deal_id || ''),\n  company_id: String(dealData.company_id || ''),\n  empresa: String(dealData.empresa || ''),\n  status: String(dealData.status || ''),\n  owner: String(dealData.owner || 'Abraham Lopez'),\n  mrr: Number(dealData.mrr || 0),\n  acv: Number(dealData.acv || 0),\n  industria: String(dealData.industria || ''),\n  canal: String(dealData.canal || ''),\n  notes: String(dealData.notes || ''),\n  contact_id: String(best.id || ''),\n  contact_name: String(best.nombre || ''),\n  contact_cargo: String(best.cargo || ''),\n  contact_email: email,\n  contact_phone: String(best.telefono || ''),\n}}];"
      },
