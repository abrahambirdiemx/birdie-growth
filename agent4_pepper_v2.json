      "name": "HTTP Request - Claude Classify",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1400, 200],
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "TU_ANTHROPIC_KEY"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({\n  model: \"claude-haiku-4-5-20251001\",\n  max_tokens: 50,\n  system: \"Clasifica este email de respuesta en UNA sola palabra: interesado | pide_info | no_interesado | fuera_oficina | conecta_dm | otro. Solo responde la clasificación, nada más.\",\n  messages: [{ role: \"user\", content: \"Tipo de contacto: \" + $json.tipo_contacto + \"\\nEmail recibido: \" + ($json.snippet || $json.body || '') }]\n}) }}",
        "options": {
