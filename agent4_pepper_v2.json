            "response": {
              "neverError": true
            }
          }
        }
      }
    },
    {
      "id": "c9d0e1f2",
      "name": "Code - Parse Classification",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1600, 200],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const resp = $input.item.json;\nconst text = (resp?.content?.[0]?.text || 'otro').toLowerCase().trim();\nconst valid = ['interesado','pide_info','no_interesado','fuera_oficina','conecta_dm','otro'];\nconst clasificacion = valid.find(v => text.includes(v)) || 'otro';\nlet prev = {};\ntry { prev = $('Merge Email + Contact').item.json || {}; } catch(e) {}\nreturn { json: { ...prev, clasificacion } };"
      }
    },
