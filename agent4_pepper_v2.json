    {
      "id": "d4e5f6a7",
      "name": "Code - Extract Sender Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [600, 300],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const msg = $input.item.json;\nconst from = msg.from || msg.From || '';\nconst emailMatch = from.match(/[\\w.-]+@[\\w.-]+\\.\\w+/);\nconst senderEmail = emailMatch ? emailMatch[0].toLowerCase() : '';\nconst threadId = msg.threadId || msg.id || '';\nconst msgId = msg.id || '';\nreturn { json: { ...msg, senderEmail, threadId, msgId } };"
      }
    },
