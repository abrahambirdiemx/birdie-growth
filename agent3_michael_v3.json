      "name": "HTTP Request Claude DM",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1120, 260],
      "credentials": {
        "httpHeaderAuth": {
          "id": "claude-api-cred",
          "name": "Claude API"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-3-5-sonnet-20241022\",\n  \"max_tokens\": 1024,\n  \"system\": \"Eres Abraham López, Director de Growth de Birdie (trybirdie.ai). Redacta un email corto y natural para un contacto interno de una empresa importadora (NO es el tomador de decisiones). Objetivo: conseguir que te conecte con quien decide sobre logística/importaciones. REGLAS: máximo 90 palabras, tono amigable y conversacional, NO menciones precio ni hagas pitch de ventas, pide explícitamente ser conectado con la persona que maneja importaciones/logística. Formato exacto: [SUBJECT: asunto aquí]\\n\\ncuerpo del email aquí\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Escribe un email para un referidor interno:\\nNombre: {{ $json.nombre }}\\nCargo: {{ $json.cargo }}\\nEmpresa: {{ $json.company?.nombre || '' }}\\nContexto: {{ $json.contexto_email }}\"\n    }\n  ]\n}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "a3v3-node-05b",
      "name": "HTTP Request Claude Referidor",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1120, 540],
      "credentials": {
        "httpHeaderAuth": {
          "id": "claude-api-cred",
          "name": "Claude API"
        }
      }
    },
    {
      "parameters": {
        "mode": "passThrough",
        "output": "input1"
      },
      "id": "a3v3-node-06",
      "name": "Merge",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [1340, 400]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst claudeResponse = items[0].json;\nlet contactData = {};\ntry {\n  contactData = $('SplitInBatches').all()[0].json || {};\n} catch(e) {}\n\nconst text = claudeResponse?.content?.[0]?.text || '';\nconst subjectMatch = text.match(/\\[SUBJECT:\\s*(.+?)\\]/);\nconst subject = subjectMatch ? subjectMatch[1].trim() : 'Birdie - Plataforma de Comercio Exterior';\nconst body = text.replace(/\\[SUBJECT:[^\\]]+\\]\\n?/, '').trim();\nconst tokens = (claudeResponse?.usage?.input_tokens || 0) + (claudeResponse?.usage?.output_tokens || 0);\n\nreturn [{\n  json: {\n    contact_id: String(contactData.id || ''),\n    company_id: String(contactData.company_id || ''),\n    empresa_nombre: String(contactData.company?.nombre || ''),\n    canal: String(contactData.company?.canal || ''),\n    email_address: String(contactData.email || ''),\n    tipo_contacto: String(contactData.tipo_contacto || ''),\n    email_subject: subject,\n    email_generado: body,\n    tokens_claude: String(tokens),\n    fecha_envio: new Date().toISOString().slice(0, 10)\n  }\n}];"
      },
