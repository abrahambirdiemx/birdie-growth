    {
      "id": "node-filter-overdue",
      "name": "Filter 5+ Days No Reply",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 240],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const fiveDaysMs = 5 * 24 * 60 * 60 * 1000;\nconst now = Date.now();\n\nconst filtered = $input.all().filter(item => {\n  const row = item.json;\n  // Must have fecha_envio and no clasificacion_respuesta yet\n  if (!row.fecha_envio || row.clasificacion_respuesta) return false;\n  \n  const sendDate = new Date(row.fecha_envio);\n  if (isNaN(sendDate.getTime())) return false;\n  \n  const daysSinceSent = now - sendDate.getTime();\n  return daysSinceSent >= fiveDaysMs;\n});\n\nreturn filtered;"
      }
    },
    {
      "id": "node-followup-split",
