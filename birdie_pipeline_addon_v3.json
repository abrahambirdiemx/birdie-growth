    {
      "id": "node-claude-followup",
      "name": "Claude Haiku Follow-up Draft",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1120, 240],
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-haiku-4-5-20251001\",\n  \"max_tokens\": 300,\n  \"system\": \"Eres Abraham López, Director de Growth de Birdie (birdie.mx), una plataforma de IA para importadores mexicanos. Redacta un follow-up breve y natural (máx 80 palabras) para un prospecto que no respondió tu primer email hace 5 días. Sé directo, no insistente. Menciona brevemente el valor específico de Birdie para su sector. Sin markdown. Solo el cuerpo del email, sin asunto ni firma.\",\n  \"messages\": [{\n    \"role\": \"user\",\n    \"content\": \"Escribe el follow-up para:\\n- Nombre: {{ $json.nombre }}\\n- Empresa: {{ $json.empresa }}\\n- Cargo: {{ $json.cargo }}\\n- Sector: {{ $json.sector }}\\n- Pain point conocido: {{ $json.pain_point }}\\n- Asunto del email original: {{ $json.email_subject }}\\n\\nEl follow-up debe ser natural, recordar brevemente de qué se trataba el email anterior y preguntar si tienen 15 minutos para una llamada.\"\n  }]\n}",
        "options": {
          "response": {
            "response": {
              "neverError": true,
              "responseFormat": "json"
            }
          }
        }
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "claude-api-credential",
          "name": "Claude API"
        }
      }
    },
    {
      "id": "node-extract-followup-text",
      "name": "Extract Follow-up Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1340, 240],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const claudeResponse = $input.item.json;\nconst prospectData = $('Follow-up SplitInBatches').item.json;\n\nconst followUpText = claudeResponse?.content?.[0]?.text || '';\nconst today = new Date().toISOString().split('T')[0];\n\nreturn {\n  json: {\n    followUpText,\n    nombre: prospectData.nombre,\n    empresa: prospectData.empresa,\n    email: prospectData.email,\n    email_subject: prospectData.email_subject,\n    row_number: prospectData.row_number,\n    notas: prospectData.notas,\n    today\n  }\n};"
      }
    },
    {
      "id": "node-send-followup-gmail",
      "name": "Send Follow-up via Gmail",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [1560, 240],
      "parameters": {
        "operation": "send",
        "sendTo": "={{ $json.email }}",
        "subject": "=Re: {{ $json.email_subject }}",
        "message": "={{ $json.followUpText }}\n\nSaludos,\nAbraham López\nDirector de Growth | Birdie\nbirdie.mx",
        "options": {
          "replyTo": "abraham@birdie.mx",
          "appendAttribution": false
        }
      },
      "credentials": {
        "gmailOAuth2": {
          "id": "gmail-credential",
          "name": "Gmail"
        }
      }
    },
