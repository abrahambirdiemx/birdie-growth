        "jsCode": "const dealResponse = $input.item.json;\nconst prospectData = $('Pipedrive SplitInBatches').item.json;\nconst today = new Date().toISOString().split('T')[0];\n\nconst dealId = dealResponse?.data?.id || null;\n\nreturn {\n  json: {\n    deal_id: dealId,\n    empresa: prospectData.empresa,\n    nombre: prospectData.nombre,\n    email: prospectData.email,\n    row_number: prospectData.row_number,\n    notas: prospectData.notas,\n    today,\n    pipedrive_note: dealId ? `pipedrive_created: ${dealId}` : 'pipedrive_error'\n  }\n};"
