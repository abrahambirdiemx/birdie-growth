    {
      "id": "c1d2e3f4",
      "name": "Code - Match Contact to Deal",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1340, 300],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst contacts = items.map(i => i.json);\nlet dealData = {};\ntry {\n  const batchItems = $('SplitInBatches').all();\n  dealData = (batchItems && batchItems[0]) ? batchItems[0].json : {};\n} catch(e) {}\n\nconst empresa = (dealData.empresa || '').toLowerCase().trim();\nconst matches = contacts.filter(c => {\n  const cEmp = (c.empresa || '').toLowerCase().trim();\n  return cEmp && empresa && (cEmp.includes(empresa.split(' ')[0]) || empresa.includes(cEmp.split(' ')[0]));\n}).filter(c => c.email && String(c.email).includes('@'));\n\n// Prefer decision makers\nconst dm = matches.find(c => c.tipo_contacto === 'decision_maker');\nconst best = dm || matches[0];\n\nif (!best) {\n  return [{ json: { _no_contact: true, empresa: dealData.empresa, status: dealData.status } }];\n}\n\nconst emailRaw = String(best.email || '');\nconst email = emailRaw.replace(/\\[([^\\]]+)\\]\\([^)]+\\)/, '$1').trim();\n\nreturn [{ json: {\n  deal_id: String(dealData.deal_id || ''),\n  empresa: String(dealData.empresa || ''),\n  status: String(dealData.status || ''),\n  owner: String(dealData.owner || ''),\n  mrr: Number(dealData.mrr || 0),\n  acv: Number(dealData.acv || 0),\n  notes: String(dealData.notes || ''),\n  contact_name: String(best.nombre || ''),\n  contact_cargo: String(best.cargo || ''),\n  contact_email: email,\n  pain_point: String(best.pain_point || ''),\n  contexto: String(best.contexto_email || ''),\n  tipo: String(best.tipo_contacto || 'otro'),\n}}];"
      }
    },
