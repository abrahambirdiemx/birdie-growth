      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2440, 180],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst resp = items[0].json;\nlet batchData = {};\ntry { batchData = $('SplitInBatches').all()[0].json || {}; } catch(e) {}\nlet contactData = {};\ntry { contactData = $('Code - Match Contact to Deal').all()[0].json || {}; } catch(e) {}\n\nconst text = resp?.content?.[0]?.text || '';\nconst subjectMatch = text.match(/\\[SUBJECT:\\s*(.+?)\\]/);\nconst subject = subjectMatch ? subjectMatch[1].trim() : 'Birdie - Seguimiento';\nconst body = text.replace(/\\[SUBJECT:[^\\]]+\\]\\n?/, '').trim();\n\nreturn [{ json: {\n  deal_id: String(contactData.deal_id || batchData.deal_id || ''),\n  empresa: String(contactData.empresa || batchData.empresa || ''),\n  status: String(contactData.status || batchData.status || ''),\n  contact_email: String(contactData.contact_email || ''),\n  contact_name: String(contactData.contact_name || ''),\n  email_subject: subject,\n  email_body: body,\n  acv: Number(contactData.acv || 0),\n}}];"
      }
