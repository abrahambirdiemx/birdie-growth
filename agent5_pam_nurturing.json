    {
      "id": "c9d0e1f2",
      "name": "Code - Filter and Prepare",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 300],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst deals = Array.isArray(items[0].json) ? items[0].json : [];\nconst today = new Date().toISOString().slice(0,10);\nconst filtered = deals.filter(d => {\n  if (!d.opportunity_name) return false;\n  const nt = d.next_touchpoint;\n  return !nt || nt <= today;\n});\nreturn filtered.map(d => ({ json: {\n  deal_id: String(d.id || ''),\n  empresa: String(d.opportunity_name || ''),\n  status: String(d.status || ''),\n  owner: String(d.owner || ''),\n  mrr: Number(d.mrr || 0),\n  acv: Number(d.acv || 0),\n  next_touchpoint: String(d.next_touchpoint || ''),\n  notes: String(d.notes || ''),\n  size: String(d.size || ''),\n  estrategia: String(d.estrategia || ''),\n}}));"
      }
    },
