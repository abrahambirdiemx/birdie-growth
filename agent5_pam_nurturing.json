        "sendBody": true,
        "contentType": "json",
        "jsonBody": "={{ JSON.stringify({\n  model: \"claude-haiku-4-5-20251001\",\n  max_tokens: 300,\n  system: \"Eres Abraham López, Director de Growth de Birdie (birdie.mx), plataforma de AI para comercio exterior en México. Redacta un email de REACTIVACIÓN cálido y profesional para un prospecto que está en Cool Off. El objetivo es reabrir la conversación sin presionar. Menciona que han pasado un tiempo y que tienes algo nuevo que compartir. Máximo 100 palabras. Sin markdown. Firma como Abraham López | Birdie. Formato exacto: [SUBJECT: asunto aquí]\\n\\ncuerpo del email aquí\",\n  messages: [{ role: \"user\", content: \"Reactiva este prospecto:\\nEmpresa: \" + $json.empresa + \"\\nContacto: \" + $json.contact_name + \" (\" + $json.contact_cargo + \")\\nÚltimo touchpoint: \" + ($json.notes || 'hace tiempo') + \"\\nACV potencial: $\" + $json.acv }]\n}) }}",
        "options": {
          "response": {
