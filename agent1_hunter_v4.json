      "id": "a1v4-node-05",
      "name": "HTTP Request Hunter",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1120, 200]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst input = items[0].json;\n\nlet companyData = {};\ntry {\n  const batchItems = $('SplitInBatches').all();\n  companyData = (batchItems && batchItems[0]) ? batchItems[0].json : {};\n} catch(e) { companyData = {}; }\n\nconst emails = (input.data && input.data.emails) ? input.data.emails : [];\nconst company_id = String(companyData.id || '');\nconst empresa_nombre = String(companyData.nombre || '');\nconst canal = String(companyData.canal || '');\n\nif (emails.length === 0) {\n  return [{ json: { _no_contacts: true, company_id, empresa_nombre } }];\n}\n\nconst DM_KW = ['director','vp ','gerente general','gerente de log','gerente de import','gerente de operac','gerente de supply','gerente de compras','jefe de log','jefe de import','jefe de operac','subdirector','ceo','coo','head of','managing'];\nconst REF_KW = ['coordinador','analista','especialista','supervisor','ejecutivo de import','ejecutivo de log'];\nconst DEPT = ['management','logistics','operations','supply','purchasing','imports','export'];\n\nconst scored = emails\n  .filter(e => e.value && String(e.value).includes('@'))\n  .map(e => {\n    const pos = String(e.position || '').toLowerCase();\n    const dept = String(e.department || '').toLowerCase();\n    let score = 0, tipo = 'otro';\n    if (DM_KW.some(k => pos.includes(k))) { score += 10; tipo = 'decision_maker'; }\n    else if (REF_KW.some(k => pos.includes(k))) { score += 5; tipo = 'referidor'; }\n    if (DEPT.some(k => dept.includes(k))) score += 3;\n    return {\n      email: String(e.value || ''),\n      nombre: String((e.first_name || '') + ' ' + (e.last_name || '')).trim(),\n      cargo: String(e.position || ''),\n      telefono: String(e.phone_number || ''),\n      linkedin: String(e.linkedin || ''),\n      confidence: Number(e.confidence || 0),\n      score, tipo\n    };\n  })\n  .sort((a, b) => b.score - a.score);\n\nconst dms = scored.filter(e => e.tipo === 'decision_maker').slice(0, 2);\nconst refs = scored.filter(e => e.tipo === 'referidor').slice(0, 3);\nconst selected = [...dms, ...refs];\n\nif (selected.length === 0) {\n  return [{ json: { _no_contacts: true, company_id, empresa_nombre } }];\n}\n\nreturn selected.map((e, i) => ({\n  json: {\n    company_id,\n    empresa: empresa_nombre,\n    nombre: e.nombre,\n    cargo: e.cargo,\n    tipo_contacto: e.tipo,\n    email: e.email,\n    telefono: e.telefono,\n    linkedin: e.linkedin,\n    estado: 'nuevo',\n    notas: 'Hunter: ' + e.confidence + '% | Canal: ' + canal\n  }\n}));"
      },
