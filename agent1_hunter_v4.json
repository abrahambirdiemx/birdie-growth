        "url": "={{ (() => { let w = String($json['web'] || '').trim(); const md = w.match(/\\[([^\\]]+)\\]\\([^)]*\\)/); if (md) w = md[1]; return 'https://api.hunter.io/v2/domain-search?domain=' + w.replace(/^https?:\\/\\//i,'').replace(/^www\\./i,'').split('/')[0].toLowerCase().trim() + '&api_key=efee88633f610ce7b47f7f495da22b41bea2b685'; })() }}",
