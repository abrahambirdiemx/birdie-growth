    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleGeminiApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": \"Eres un investigador de inteligencia comercial especializado en importadores mexicanos.\\nEmpresa: {{ $json.company?.nombre || $json.nombre }}\\nCanal: {{ $json.company?.canal || '' }}\\nCargo del contacto: {{ $json.cargo }}\\nTipo de contacto: {{ $json.tipo_contacto }}\\n\\nGenera EXACTAMENTE este JSON sin texto adicional:\\n{\\\"resumen\\\":\\\"2-3 oraciones sobre qué importa esta empresa y sus operaciones\\\",\\\"pain_point\\\":\\\"el problema aduanal o logístico más probable (ej: demoras, costos de almacenaje, clasificación arancelaria)\\\",\\\"contexto_email\\\":\\\"dato específico y concreto para personalizar el email (diferente según si es decision_maker o referidor)\\\"}\"\n        }\n      ]\n    }\n  ]\n}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "a2v3-node-04",
      "name": "HTTP Request Gemini",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 300],
      "credentials": {
        "httpQueryAuth": {
          "id": "gemini-api-cred",
          "name": "Gemini API"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst geminiResponse = items[0].json;\nlet batchData = {};\ntry {\n  const batchItems = $('SplitInBatches').all();\n  batchData = (batchItems && batchItems[0]) ? batchItems[0].json : {};\n} catch(e) {}\n\nconst raw = geminiResponse?.candidates?.[0]?.content?.parts?.[0]?.text || '';\nlet parsed = { resumen: '', pain_point: '', contexto_email: '' };\ntry {\n  const clean = raw.replace(/```json\\n?|\\n?```/g, '').trim();\n  parsed = JSON.parse(clean);\n} catch(e) {\n  parsed = { resumen: raw.slice(0, 200), pain_point: '', contexto_email: '' };\n}\n\nreturn [{\n  json: {\n    contact_id: String(batchData.id || ''),\n    empresa: String(batchData.company?.nombre || batchData.nombre || ''),\n    tipo_contacto: String(batchData.tipo_contacto || ''),\n    email: String(batchData.email || ''),\n    investigacion: String(parsed.resumen || ''),\n    pain_point: String(parsed.pain_point || ''),\n    contexto_email: String(parsed.contexto_email || ''),\n    estado: 'investigado'\n  }\n}];"
      },
